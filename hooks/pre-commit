#!/bin/sh
# Cartograph — aktualisiert die Projekt-Karte bei jedem Commit. Blockiert NIE den Commit.
# Aktiviert via `cartograph install-hook` (setzt core.hooksPath auf .cartograph/hooks).

ROOT="$(git rev-parse --show-toplevel)"

# cartograph finden (global installiert oder via npx)
CARTO="$(command -v cartograph 2>/dev/null)"
if [ -z "$CARTO" ] && command -v npx >/dev/null 2>&1; then
  CARTO="npx --no-install cartograph"
fi
if [ -z "$CARTO" ]; then
  echo "ℹ️  Cartograph not found — map not updated. (npm i -g cartograph)"
  exit 0
fi

# Rebuild the map (also warns on critical changes without a memory/ note)
$CARTO build --quiet || { echo "⚠️  Cartograph build failed — map may be stale (commit continues)."; exit 0; }

# aktualisierte Karte in denselben Commit aufnehmen (graph.json ist .gitignore'd → nur die Karte)
git add "$ROOT/.cartograph/ARCHITECTURE.md" 2>/dev/null

exit 0
