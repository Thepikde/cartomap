#!/bin/sh
# Cartograph — aktualisiert die Projekt-Karte bei jedem Commit. Blockiert NIE den Commit.
# Aktiviert via `cartograph install-hook` (setzt core.hooksPath auf .cartograph/hooks).

ROOT="$(git rev-parse --show-toplevel)"

# cartograph finden (global installiert oder via npx)
CARTO="$(command -v cartograph 2>/dev/null)"
if [ -z "$CARTO" ] && command -v npx >/dev/null 2>&1; then
  CARTO="npx --no-install cartograph"
fi
if [ -z "$CARTO" ]; then
  echo "ℹ️  Cartograph nicht gefunden — Karte nicht aktualisiert. (npm i -g cartograph)"
  exit 0
fi

# Karte neu bauen (gibt bei kritischen Änderungen ohne memory/-Notiz einen Hinweis aus)
$CARTO build --quiet || { echo "⚠️  Cartograph-Build fehlgeschlagen — Karte evtl. veraltet (Commit läuft weiter)."; exit 0; }

# aktualisierte Karte in denselben Commit aufnehmen
git add "$ROOT/.cartograph/ARCHITECTURE.md" "$ROOT/.cartograph/graph.json" 2>/dev/null

exit 0
