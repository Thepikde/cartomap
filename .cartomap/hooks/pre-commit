#!/bin/sh
# Cartomap — aktualisiert die Projekt-Karte bei jedem Commit. Blockiert NIE den Commit.
# Aktiviert via `cartomap install-hook` (setzt core.hooksPath auf .cartomap/hooks).

ROOT="$(git rev-parse --show-toplevel)"

# cartomap finden (global installiert oder via npx)
CARTO="$(command -v cartomap 2>/dev/null)"
if [ -z "$CARTO" ] && command -v npx >/dev/null 2>&1; then
  CARTO="npx --no-install cartomap"
fi
if [ -z "$CARTO" ]; then
  echo "ℹ️  Cartomap not found — map not updated. (npm i -g cartomap)"
  exit 0
fi

# Rebuild the map (also warns on critical changes without a memory/ note)
$CARTO build --quiet || { echo "⚠️  Cartomap build failed — map may be stale (commit continues)."; exit 0; }

# aktualisierte Karte in denselben Commit aufnehmen (graph.json ist .gitignore'd → nur die Karte)
git add "$ROOT/.cartomap/ARCHITECTURE.md" 2>/dev/null

exit 0
